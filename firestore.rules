rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users collection
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true);
    }
    
    // Fallback for all other collections (projects, tickets, hourLogs, registryUsers)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
